  "description": "ACEHarness - Agent Centric Engineering Harness (From Cangjie Team)",
  "scripts": {
    "build:cli": "node scripts/build-cli.js",
    "dev": "npm run build:cli && node server.js dev",
    "build": "npm run build:cli && next build",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','.next','dist-build']) fs.rmSync(p,{recursive:true,force:true});\"",
    "start": "node server.js start",
    "lint": "next lint",
    "test": "vitest run",
    "test:components": "vitest run tests/components --environment jsdom",
    "ace": "node ./bin/ace.js",
    "prepare": "node scripts/build-cli.js",
    "prepack": "npm run build",
    "publish:npm": "npm run build && npm publish",
    "publish:beta": "npm run build && npm publish --tag beta"
  },
  "keywords": [
    "ai",
    "orchestration",
    "claude"
  ],
  "author": "CangjieLang",
  "repository": {
